# This .gitignore is for Unity projects
# ================================================================================

# ================================================================================
# Unity generated artifacts
# ================================================================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# ================================================================================
# Unity generated visual studio files
# ================================================================================
*.csproj
*.unityproj
*.sln
*.suo
*.user
*.userossc
*.userprefs
*.booproj
/.vs/

# ================================================================================
# JetBrains Rider
# ================================================================================
.idea/
*.sln.DotSettings.user

# ================================================================================
# VS Code (keep for team consistency, but ignore workspace files)
# ================================================================================
.vscode/

# ================================================================================
# OS generated
# ================================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ================================================================================
# Unity specific
# ================================================================================
# Asset meta data should only be ignored when selectively
!/Assets/**/*.meta

# Uncomment this line if you don't want Unity created project folders
# [Pp]rojectSettings/

# Crash Reports
/crashlytics/

# Screenshots (not needed in version control)
Assets/Screenshots/
Assets/Screenshots.meta

# Unity recovery files from crashes
Assets/_Recovery/
Assets/_Recovery.meta

# Scene templates (auto-generated by Unity)
Assets/Settings/Scenes/
Assets/Settings/Scenes.meta
Assets/Settings/Lit2DSceneTemplate.scenetemplate*
ProjectSettings/SceneTemplateSettings.json

# Gradle build artifacts (Android)
gradle/
.gradle/
local.properties
*.apk
*.aab

# iOS
*.app
*.ipa
*.dSYM.zip
*.dSYM

# Burst
**/BurstDebugInformation_DoNotShip/
**/BackUpThisFolder_ButDontShipItWithYourGame/

# Unity Android temp
.utmp/
*.so
